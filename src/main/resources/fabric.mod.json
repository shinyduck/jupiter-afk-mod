	"authors": [
		"shinyduck"
	],
	"contact": {
		"homepage": "https://github.com/shinyduck/jupiter-afk-mod",
		"sources": "https://github.com/shinyduck/jupiter-afk-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/afkmod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"me.jupiter.afk.AFKMod"
		]
	},
	"mixins": [
		"afkmod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}